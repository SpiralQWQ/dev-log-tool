{
  "_schema_version": "1.0",
  "_description": "终端历史采集敏感词过滤规则，Hybrid 白名单+黑名单模式",
  "_last_updated": "2026-07-18",
  "whitelist_prefixes": [
    "git",
    "pip",
    "python",
    "npm",
    "node",
    "npx",
    "yarn",
    "pnpm",
    "docker",
    "cargo",
    "rustc",
    "cd",
    "ls",
    "dir",
    "code",
    "cat",
    "echo",
    "type",
    "more",
    "less",
    "head",
    "tail",
    "grep",
    "find",
    "Select-String",
    "mkdir",
    "cp",
    "copy",
    "mv",
    "move",
    "rm",
    "remove",
    "ni",
    "new-item",
    "codegraph",
    "onefetch",
    "cls",
    "clear",
    "exit",
    "winget",
    "choco",
    "tree",
    "Get-ChildItem",
    "Get-Item",
    "Get-Content",
    "Set-Location",
    "Write-Host",
    "Write-Output",
    "Read-Host",
    "Measure-Command",
    "Test-Path",
    "Start-Process",
    "Invoke-WebRequest",
    "Invoke-RestMethod",
    "ConvertTo-Json",
    "ConvertFrom-Json",
    "curl",
    "wget",
    "pwd",
    "whoami",
    "hostname",
    "systeminfo",
    "tasklist",
    "netstat",
    "ipconfig",
    "ping",
    "ssh",
    "scp",
    "sftp"
  ],
  "blacklist_patterns": [
    {"regex": "sk-[A-Za-z0-9_-]{20,}", "action": "block"},
    {"regex": "sk-\\w{20,}", "action": "block"},
    {"regex": "(?i)key\\s*[=:]\\s*[A-Za-z0-9%/+]{16,}", "action": "block"},
    {"regex": "(?i)token\\s*[=:]\\s*[A-Za-z0-9%/+._-]{16,}", "action": "block"},
    {"regex": "(?i)api.?key\\s*[=:]\\s*[A-Za-z0-9%/+._-]{8,}", "action": "block"},
    {"regex": "(?i)apikey\\s*[=:]\\s*[A-Za-z0-9%/+._-]{8,}", "action": "block"},
    {"regex": "(?i)password\\s*[=:]\\s*[A-Za-z0-9%!@#$%^&*()]{4,}", "action": "block"},
    {"regex": "(?i)secret\\s*[=:]\\s*[A-Za-z0-9%!@#$%^&*()]{4,}", "action": "block"},
    {"regex": "Bearer\\s+[A-Za-z0-9._-]{20,}", "action": "block"},
    {"regex": "(?i)\\$env:\\w*(?:KEY|TOKEN|SECRET|PASSWORD)\\w*", "action": "block"},
    {"regex": "https?://[A-Za-z0-9._%+-]+:[A-Za-z0-9._%+-]+@", "action": "redact"},
    {"regex": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}", "action": "block"}
  ],
  "_note": "执行顺序: 白名单优先 → 白名单外过黑名单 → 通过的保留"
}
